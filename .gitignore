# Fedora toolkit — host-generated runtime (see lib/health_snapshot.sh)
runtime/health/latest.json
runtime/health/latest.txt
runtime/health/history/*.json
runtime/health/history/*.txt

# Operational logs (see logs/README.md)
logs/*.log
logs/archive/
logs/backups/
logs/security_audit/
logs/host_context/
logs/hardening/
logs/readiness/
!logs/README.md

# Local secrets / environment
.env
.env.*
*.env
*.local
*.secret
*.key

# Python cache / local tooling
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.venv/
venv/

# Node / frontend local deps
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Generic build / coverage artifacts
build/
dist/
coverage/
htmlcov/
*.cover
*.coverage
.coverage.*

# Editor / OS clutter
.DS_Store
Thumbs.db
*.swp
*.swo
*~
